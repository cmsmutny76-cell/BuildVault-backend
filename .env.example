# RevenueCat API Configuration
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your_ios_api_key_here
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=test_gEXCOKhBXscVhavZesQcP1LAfH

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/construction_leads

# AWS S3 Configuration (for photo storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=construction-app-photos

# Stripe Configuration (for contractor subscriptions)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Subscription Settings
CONTRACTOR_TRIAL_DAYS=30
CONTRACTOR_MONTHLY_PRICE=49.99

# Unified API Configuration (web + mobile)
# Backend local URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared auth/profile store
# File-backed fallback for local and simple hosted deployments.
# For Railway, mount persistent storage or replace with Postgres later.
AUTH_STORE_FILE_PATH=./.data/auth-store.json

# Mobile device/emulator URL (set to your machine LAN IP)
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.10:3000/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api
NODE_ENV=development

# Future: Retailer scraping configuration
