{
  "name": "construction-lead-app",
  "version": "0.1.0",
  "private": true,
  "description": "Construction lead generating app with AI-powered material estimation",
  "workspaces": [
    "mobile",
    "backend"
  ],
  "scripts": {
    "dev": "npm run backend",
    "web": "npm run backend",
    "mobile": "cd mobile && npm start",
    "backend": "cd backend && npm run dev",
    "web:build": "cd backend && npm run build",
    "web:start": "cd backend && npm run start",
    "backend:build": "cd backend && npm run build",
    "install:all": "npm install && cd mobile && npm install && cd ../backend && npm install"
  },
  "keywords": [
    "construction",
    "ai",
    "lead-generation",
    "react-native",
    "nextjs"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "openai": "^6.22.0"
  }
}
