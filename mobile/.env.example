# RevenueCat API Keys
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your_ios_api_key_here
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=your_android_api_key_here

# Shared backend API used by both mobile and web
# Use localhost for emulator/web; use LAN IP for physical device
# Example (physical phone): EXPO_PUBLIC_API_URL=http://192.168.1.10:3000/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api
